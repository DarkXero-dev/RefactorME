# Refaktor.me, site-preview generator configuration.
# Copy to .env for local server testing, or paste these into your host's
# dashboard (Vercel / Cloudflare / Netlify) at live deploy. Every value has a
# safe default, so the draft runs with none of these set.
#
# IMPORTANT: this feature spends money per use (one Claude call + one screenshot
# call per generate). The caps below are the spending brake. Start them low.

# Site status indicator. false shows a red pulsating "offline" badge (topbar +
# footer); true shows a green pulsating "online". Flip to true and rebuild when
# the site actually goes live.
PUBLIC_SITE_ONLINE=false

# Master switch for the backend. Leave false for the GitHub Pages draft.
# Set to true only on a real server host to turn the generator on.
PREVIEW_ENABLED=false

# Same switch, exposed to the browser so the front-end button is wired up.
# Keep this in sync with PREVIEW_ENABLED.
PUBLIC_PREVIEW_ENABLED=false

# Anthropic API key for generating the modernized homepage HTML.
# Get one at https://console.anthropic.com (API Keys). Format: sk-ant-...
ANTHROPIC_API_KEY=

# HTML-to-image service key (ScreenshotOne by default).
# Sign up at https://screenshotone.com, copy the access key from the dashboard.
SCREENSHOT_API_KEY=

# Cloudflare Turnstile (free bot protection in front of the generate button).
# Create a widget at https://dash.cloudflare.com (Turnstile). You get two keys:
#   - the SECRET key goes here (server side)
#   - the SITE KEY goes in PUBLIC_TURNSTILE_SITEKEY below (browser side)
TURNSTILE_SECRET=
PUBLIC_TURNSTILE_SITEKEY=

# Spending brakes. Tune to taste.
DAILY_GENERATE_CAP=100      # hard ceiling on total generates per day, everyone
PER_IP_HOURLY_LIMIT=3       # generates allowed per visitor IP per hour
CACHE_TTL_HOURS=24          # how long a generated image is reused for the same URL
