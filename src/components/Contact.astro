---
---

<section id="contact">
  <div class="wrap">
    <div class="panel cta-box reveal">
      <span class="tag">say hello</span>
      <h2>Ready when <span class="grad">you are</span>.</h2>
      <p>Tell us what you have and what you want. We take it from there.</p>
      <a href="mailto:hello@refactor.me" class="btn big">
        hello@refactor.me
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M7 17 17 7M9 7h8v8" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-box{
    padding:clamp(2rem,5vw,3.4rem);text-align:center;
    background:
      radial-gradient(120% 140% at 50% -20%, rgba(79,140,255,.16), transparent 60%),
      linear-gradient(180deg, var(--panel), var(--panel-deep));
  }
  .cta-box .tag{display:inline-block}
  .cta-box h2{margin-bottom:.7rem}
  .cta-box p{color:var(--muted);max-width:42ch;margin:0 auto 1.6rem}
  .btn.big{font-size:1.05rem;padding:.85rem 1.4rem}
</style>
