---
// Expandable FAQ. Native <details>/<summary>: accessible, keyboard-friendly,
// zero JS, no bloat. Same Q/A feed the FAQPage structured data below for
// rich results in search.
// Six questions, kept tight on purpose: the things a buyer needs settled before
// getting in touch. Anything already answered elsewhere on the page (turnaround,
// who does the work, maintenance) is left to that section rather than repeated.
const faqs = [
  [
    'Do I keep my domain and hosting?',
    'Yes. Your domain and hosting stay yours, in your name, where they belong. I work with whatever you already have, or help you move somewhere simpler if you fancy it.',
  ],
  [
    'I only need a small tweak, not a full rebuild.',
    'That is fine, and small jobs are genuinely welcome. Tell me what you need and I will price exactly that, not a full rebuild you never asked for.',
  ],
  [
    'How much does it cost?',
    "Most projects start at €150, which covers a clean rebuild of a simple site, phones included. From there it comes down to scope: more pages, more features, or more content to untangle means a higher price, and larger builds can run well beyond that. Whatever it lands on, you get the exact number before any work starts. No surprises, no rounding up on a Friday.",
  ],
  [
    'How does payment work?',
    "Payment is up front, before I start. I keep the jobs small and the prices low on purpose, so this is a modest one-off amount, not a big commitment. You see the exact price, scope, and timeline in writing before you pay anything, and if it isn't right for you, you owe me nothing and there are no hard feelings.",
  ],
  [
    'How many revisions are included?',
    "Two rounds are included in every quote, which is normally more than enough once you have seen the first build. Anything past that is quick to do and priced separately, always agreed before it happens rather than after.",
  ],
  [
    'Have you done this before?',
    'Plenty of times. <b class="rk">Refaktor</b> is new, but the work is not. I have spent years building and rebuilding my own sites, and years before that inside Apple\'s ecosystem, watching real people wrestle with technology. What you get is me on your project directly: no account manager, no support ticket, and a price that is not propping up an office. The longer story is <a href="/about">on the about page</a>.',
  ],
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(([q, a]) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a.replace(/<[^>]+>/g, '') },
  })),
};
---

<section id="faq">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="tag">questions</span>
        <h2>Before you <span class="grad">ask</span>.</h2>
      </div>
      <p>The things people want to know before getting in touch.</p>
    </div>

    <div class="faqlist reveal">
      {faqs.map(([q, a], i) => (
        <details class="faq" open={i === 0}>
          <summary>
            <span class="q">{q}</span>
            <span class="ind" aria-hidden="true"></span>
          </summary>
          <div class="a"><p set:html={a}></p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<style>
  .faqlist{display:grid;gap:.7rem}
  .faq{
    background:linear-gradient(180deg, var(--panel), var(--panel-deep));
    border:1px solid var(--line);border-radius:14px;overflow:hidden;
    transition:border-color .18s var(--ease);
  }
  .faq[open]{border-color:var(--line-2)}
  .faq summary{
    display:flex;align-items:center;justify-content:space-between;gap:1rem;
    padding:1.05rem 1.2rem;cursor:pointer;list-style:none;
    font-weight:600;font-size:1rem;letter-spacing:-.01em;color:var(--text);
  }
  .faq summary::-webkit-details-marker{display:none}
  .faq summary:hover .q{color:#fff}
  .faq .q{flex:1;text-wrap:balance}
  /* plus / minus indicator */
  .ind{position:relative;flex:0 0 auto;width:18px;height:18px}
  .ind::before,.ind::after{
    content:"";position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    background:var(--cyan);border-radius:2px;transition:transform .2s var(--ease), opacity .2s var(--ease);
  }
  .ind::before{width:14px;height:2px}
  .ind::after{width:2px;height:14px}
  .faq[open] .ind::after{transform:translate(-50%,-50%) rotate(90deg);opacity:0}
  .faq .a{padding:0 1.2rem 1.15rem}
  .faq .a p{color:var(--soft);font-size:.92rem;line-height:1.6;max-width:66ch}

  @media (prefers-reduced-motion: reduce){
    .faq,.ind::before,.ind::after{transition:none}
  }
</style>
