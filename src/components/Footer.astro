---
const online = import.meta.env.PUBLIC_SITE_ONLINE === 'true';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer>
  <div class="wrap inner">
    <div class="left">
      <span class="brand">
        <img class="mark" src={`${base}favicon.svg`} alt="" width="40" height="40" />
        <span class="lockup">
          <span class="word">refaktor<span class="me">.me</span></span>
          <span class="tagline">Website rebuilds, done right</span>
        </span>
      </span>
    </div>
    <div class="right">
      <span class={`status ${online ? 'on' : 'off'}`}>status: {online ? 'all systems good' : 'offline'}</span>
      <span class="copy">&copy; {year} <span class="rk">Refaktor</span></span>
    </div>
  </div>
</footer>

<style>
  footer{border-top:1px solid var(--line);padding-block:1.8rem;margin-top:0;color:var(--muted);font-size:.86rem}
  .inner{display:flex;flex-wrap:wrap;gap:1rem 2.5rem;align-items:center;justify-content:space-between}
  .left{display:flex;flex-direction:column;gap:.4rem}
  .brand{display:flex;align-items:center;gap:.6rem;color:var(--text)}
  .brand .mark{width:40px;height:40px;border-radius:11px;flex:0 0 auto;box-shadow:0 6px 16px rgba(79,140,255,.3)}
  .brand .lockup{display:flex;flex-direction:column;line-height:1.05}
  .brand .word{font-weight:800;font-size:1.12rem;letter-spacing:-.02em}
  .brand .me{background:linear-gradient(90deg,#4f8cff,#3fc6d8);-webkit-background-clip:text;background-clip:text;color:transparent}
  .brand .tagline{margin-top:3px;font-size:.54rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
  .right{display:flex;flex-direction:column;gap:.4rem;text-align:right}
  .right .copy{color:var(--soft)}
  .status{font-family:var(--mono);font-size:.72rem;color:var(--muted)}
  .status.off{color:#ff9093}
  .status.on{color:#73e3b4}
  @media (max-width:560px){.right{text-align:left}.inner{gap:.8rem 1.1rem}}
</style>
