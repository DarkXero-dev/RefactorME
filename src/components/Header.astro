---
// Shared top bar. Used on the homepage (onHome) and standalone pages like
// /about. On the homepage the nav links are in-page anchors (#id) so the
// delegated smooth-scroll handler in Layout catches them; on other pages they
// point back at the homepage sections (<base>#id) and navigate normally.
const { onHome = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const online = import.meta.env.PUBLIC_SITE_ONLINE === 'true';
const sec = onHome ? '' : base;
const homeHref = onHome ? '#top' : base;
const aboutHref = `${base}about`;
---

<header class="topbar">
  <div class="wrap inner">
    <a href={homeHref} class="brand" aria-label="Refaktor.me, website rebuilds done right">
      <img class="mark" src={`${base}favicon.svg`} alt="" width="40" height="40" />
      <span class="lockup">
        <span class="word">refaktor<span class="me">.me</span></span>
        <span class="tagline">Website rebuilds, done right</span>
      </span>
    </a>
    <nav class="nav">
      <div class="links">
        <a href={`${sec}#rebuild`}>Why?</a>
        <a href={`${sec}#samples`}>Samples</a>
        <a href={`${sec}#pricing`}>Pricing</a>
        <a href={`${sec}#faq`}>FAQ</a>
        <a href={aboutHref}>About</a>
      </div>
      <button class="theme-btn" id="theme-btn" type="button" aria-label="Switch to light theme" aria-pressed="false" title="Toggle light / dark">
        <svg class="ic-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="2"/><path d="M12 2v2.4M12 19.6V22M4.2 4.2l1.7 1.7M18.1 18.1l1.7 1.7M2 12h2.4M19.6 12H22M4.2 19.8l1.7-1.7M18.1 5.9l1.7-1.7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <svg class="ic-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 14.4A8 8 0 0 1 9.6 4 7 7 0 1 0 20 14.4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
      </button>
      <span class={`pill ${online ? 'on' : 'off'}`}>
        <span class="dot" aria-hidden="true"></span>{online ? 'online' : 'offline'}
      </span>
      <a class="btn cta-desktop" href={`${sec}#contact`}>Get a refactor</a>
      <button class="menu-btn" id="menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span class="bars" aria-hidden="true"><i></i><i></i><i></i></span>
      </button>
    </nav>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <div class="wrap">
      <span class={`pill ${online ? 'on' : 'off'} m-pill`}>
        <span class="dot" aria-hidden="true"></span>{online ? 'online' : 'offline'}
      </span>
      <a href={`${sec}#rebuild`}>Why?</a>
      <a href={`${sec}#samples`}>Samples</a>
      <a href={`${sec}#pricing`}>Pricing</a>
      <a href={`${sec}#faq`}>FAQ</a>
      <a href={aboutHref}>About</a>
      <a class="btn m-cta" href={`${sec}#contact`}>Get a refactor</a>
    </div>
  </div>
</header>

<style>
  .topbar{
    position:sticky;top:0;z-index:50;
    border-bottom:1px solid var(--line);
    background:linear-gradient(180deg, rgba(var(--chrome),.92), rgba(var(--chrome),.6));
    backdrop-filter:saturate(140%) blur(10px);
    -webkit-backdrop-filter:saturate(140%) blur(10px);
  }
  .topbar .inner{display:flex;align-items:center;justify-content:space-between;height:64px}
  .brand{display:flex;align-items:center;gap:.65rem;color:var(--text)}
  .brand .mark{width:40px;height:40px;border-radius:11px;flex:0 0 auto;box-shadow:0 6px 18px rgba(79,140,255,.3)}
  .brand .lockup{display:flex;flex-direction:column;line-height:1.05}
  .brand .word{font-weight:800;font-size:1.16rem;letter-spacing:-.02em}
  .brand .me{background:linear-gradient(90deg,#4f8cff,#3fc6d8);-webkit-background-clip:text;background-clip:text;color:transparent}
  .brand .tagline{margin-top:3px;font-size:.56rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted)}
  .nav{display:flex;align-items:center;gap:1.6rem}
  .nav .links{display:flex;gap:1.5rem;font-size:.86rem;color:var(--muted);font-weight:500}
  .nav .links a:hover{color:var(--text)}
  .pill{
    font-family:var(--mono);font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;
    border:1px solid;border-radius:999px;padding:.36rem .7rem;
    display:inline-flex;align-items:center;gap:.42rem;
  }
  .pill .dot{
    width:7px;height:7px;border-radius:50%;flex:0 0 auto;
    animation:status-pulse 1.6s ease-in-out infinite;
  }
  /* offline: red, pulsating (default until launch) */
  .pill.off{color:#ff9093;border-color:rgba(226,72,77,.45);background:rgba(226,72,77,.1)}
  .pill.off .dot{background:#e2484d;box-shadow:0 0 8px 1px rgba(226,72,77,.7)}
  /* online: green, pulsating */
  .pill.on{color:#73e3b4;border-color:rgba(63,207,142,.45);background:rgba(63,207,142,.1)}
  .pill.on .dot{background:#3fcf8e;box-shadow:0 0 8px 1px rgba(63,207,142,.7)}
  @keyframes status-pulse{
    0%,100%{transform:scale(1);opacity:1}
    50%{transform:scale(1.3);opacity:.5}
  }
  @media (prefers-reduced-motion: reduce){.pill .dot{animation:none}}

  /* ---------- theme toggle (always visible, desktop + mobile) ---------- */
  .theme-btn{
    display:inline-flex;align-items:center;justify-content:center;
    width:40px;height:40px;flex:0 0 auto;
    background:transparent;border:1px solid var(--line);border-radius:11px;
    cursor:pointer;color:var(--soft);
    transition:color .2s var(--ease),border-color .2s var(--ease),transform .2s var(--ease);
  }
  .theme-btn:hover{border-color:var(--blue);color:var(--text);transform:translateY(-1px)}
  .theme-btn svg{display:none}
  .theme-btn .ic-sun{display:block}  /* dark default: show sun (click -> light) */
  :global(:root[data-theme="light"]) .theme-btn .ic-sun{display:none}
  :global(:root[data-theme="light"]) .theme-btn .ic-moon{display:block}

  /* ---------- hamburger ---------- */
  .menu-btn{
    display:none;
    width:42px;height:42px;flex:0 0 auto;
    align-items:center;justify-content:center;
    background:transparent;border:1px solid var(--line);border-radius:11px;
    cursor:pointer;color:var(--text);
  }
  .menu-btn:hover{border-color:var(--blue)}
  .menu-btn .bars{display:grid;gap:4px;width:18px}
  .menu-btn .bars i{display:block;height:2px;border-radius:2px;background:currentColor;transition:transform .2s var(--ease), opacity .2s var(--ease)}
  .menu-btn[aria-expanded="true"] .bars i:nth-child(1){transform:translateY(6px) rotate(45deg)}
  .menu-btn[aria-expanded="true"] .bars i:nth-child(2){opacity:0}
  .menu-btn[aria-expanded="true"] .bars i:nth-child(3){transform:translateY(-6px) rotate(-45deg)}

  /* ---------- mobile dropdown panel ---------- */
  .mobile-menu{
    display:none;
    border-bottom:1px solid var(--line);
    background:linear-gradient(180deg, rgba(var(--chrome),.98), rgba(var(--chrome),.94));
    backdrop-filter:saturate(140%) blur(10px);
    -webkit-backdrop-filter:saturate(140%) blur(10px);
  }
  .mobile-menu .wrap{display:flex;flex-direction:column;gap:.2rem;padding-block:.8rem 1.1rem}
  .mobile-menu a{
    color:var(--soft);font-weight:600;font-size:1rem;
    padding:.8rem .4rem;border-bottom:1px solid var(--line);
  }
  .mobile-menu a:last-child{border-bottom:none}
  .mobile-menu a:not(.btn):hover{color:var(--text)}
  .mobile-menu .m-pill{align-self:flex-start;margin-bottom:.4rem}
  .mobile-menu .m-cta{
    justify-content:center;margin-top:.7rem;border-bottom:none;
    color:#fff;padding:.85rem 1.1rem;
  }
  /* hidden attr must win over the media-query display:block below (closed by default) */
  .mobile-menu[hidden]{display:none}

  @media (max-width:860px){
    .nav .links{display:none}
    .nav .cta-desktop{display:none}
    .nav .pill{display:none}
    .menu-btn{display:inline-flex}
    .mobile-menu{display:block}
  }
  @media (max-width:400px){
    .topbar .wrap{height:58px}
    .brand{gap:.5rem}
    .brand .word{font-size:1.05rem}
    .brand .mark{width:34px;height:34px}
    .brand .tagline{display:none}
    .nav{gap:.6rem}
  }
  /* match the widened hero on big screens so brand + nav sit at the hero edges */
  @media (min-width:1360px){
    .topbar .inner{max-width:min(1600px,92vw)}
  }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    const setOpen = (open: boolean) => {
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      menu.hidden = !open;
    };
    btn.addEventListener('click', () => {
      setOpen(btn.getAttribute('aria-expanded') !== 'true');
    });
    // close after picking a destination
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    // close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') setOpen(false);
    });
  }

  // theme toggle: dark is the default (no attribute); flipping to light sets
  // data-theme + remembers the choice. The no-flash boot script lives in <head>.
  const themeBtn = document.getElementById('theme-btn');
  if (themeBtn) {
    const root = document.documentElement;
    const meta = document.querySelector('meta[name="theme-color"]');
    const sync = () => {
      const light = root.dataset.theme === 'light';
      themeBtn.setAttribute('aria-pressed', String(light));
      themeBtn.setAttribute('aria-label', light ? 'Switch to dark theme' : 'Switch to light theme');
      if (meta) meta.setAttribute('content', light ? '#e9edf4' : '#0f1420');
    };
    sync();
    themeBtn.addEventListener('click', () => {
      const goLight = root.dataset.theme !== 'light';
      if (goLight) root.dataset.theme = 'light';
      else delete root.dataset.theme;
      try { localStorage.setItem('theme', goLight ? 'light' : 'dark'); } catch (e) {}
      sync();
    });
  }
</script>
