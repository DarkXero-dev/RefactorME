---
import RefactorDemo from './RefactorDemo.astro';
---

<section class="hero" id="hero">
  <div class="wrap inner">
    <div class="copy">
      <div class="eyebrow reveal"><span class="live"></span> site health monitor</div>
      <h1 class="reveal">Your website is <span class="grad">calling for a refactor.</span></h1>
      <p class="sub reveal">
        I rebuild tired hobby pages, single-product sites, and the sites of family-run shops and restaurants.
        Faster, cleaner, happy on a phone, and no longer stuck in 2010.
      </p>
      <div class="cta reveal">
        <a class="btn" href="#contact">Get a refactor
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a class="btn ghost" href="#build">See what I build</a>
      </div>
      <div class="micro reveal">
        <span><i></i> No templates, no page builders</span>
        <span><i></i> Hand-written code, not a byte more</span>
      </div>
    </div>

    <div class="demo-col reveal">
      <RefactorDemo />
    </div>
  </div>

  <a class="scrollcue" href="#rebuild" aria-label="Scroll to see more">
    <span class="mouse" aria-hidden="true"><span class="wheel"></span></span>
    <span class="sc-tag">Scroll</span>
  </a>
</section>

<style>
  /* Fill exactly one screen (viewport minus the 64px sticky topbar) so the next
     section never peeks above the fold, no matter the resolution. Then scrolling
     - and the scroll cue - actually mean something. svh keeps mobile honest. */
  .hero{
    position:relative;
    min-height:calc(100vh - 64px);
    min-height:calc(100svh - 64px);
    display:flex;flex-direction:column;
    padding-top:clamp(1.4rem,3vw,2.4rem);padding-bottom:clamp(4.5rem,8vh,6rem);
  }
  .inner{display:grid;gap:clamp(1.8rem,3.4vw,3.6rem);align-items:center;align-content:center;flex:1 1 auto}
  @media (min-width:980px){.inner{grid-template-columns:1.02fr 1.18fr}}

  /* Break the hero out of the 1240px site container on big screens so it spans
     the screen instead of sitting in a narrow column with empty side bands.
     Only the hero widens; content sections below stay readable at 1240. */
  @media (min-width:1360px){
    .hero .inner{max-width:min(1600px,92vw)}
  }

  /* Short viewports (small laptops, browser chrome eating height): scale the
     whole hero - headline, subtext, spacing - DOWN so the content block does
     not crowd the scroll cue at the bottom. Card height already tracks vh. */
  @media (max-height:880px){
    .hero h1{font-size:clamp(2.1rem,1rem+2.4vw,3.9rem)}
    .hero .sub{font-size:clamp(1rem,.9rem+.3vw,1.14rem);margin-bottom:1.3rem}
    .eyebrow{margin-bottom:1rem}
    .inner{gap:clamp(1.6rem,3vw,2.8rem)}
  }
  @media (max-height:740px){
    .hero h1{font-size:clamp(2rem,1rem+2vw,3.3rem)}
  }

  .eyebrow{
    font-family:var(--mono);font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;
    color:var(--muted);display:flex;align-items:center;gap:.6rem;margin-bottom:1.3rem;
  }
  .eyebrow .live{width:8px;height:8px;border-radius:50%;background:var(--cyan);box-shadow:0 0 0 4px rgba(63,198,216,.18);animation:pulse 2s infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}

  .hero h1{
    font-weight:800;letter-spacing:-.03em;line-height:1.02;
    font-size:clamp(2.1rem, 1rem + 3.6vw, 5.2rem);
    margin-bottom:1.1rem;
  }
  .hero h1 .grad{background:var(--grad-tri);-webkit-background-clip:text;background-clip:text;color:transparent}
  .hero .sub{font-size:clamp(1rem,.9rem+.5vw,1.3rem);color:var(--soft);max-width:38rem;margin-bottom:1.6rem}
  .cta{display:flex;gap:.9rem;align-items:center;flex-wrap:wrap}
  .micro{font-size:.78rem;color:var(--muted);margin-top:1.1rem;display:flex;gap:1.2rem;flex-wrap:wrap}
  .micro span{display:flex;align-items:center;gap:.45rem}
  .micro i{width:6px;height:6px;border-radius:50%;background:var(--violet);display:inline-block}

  .demo-col :global(.rb){margin-inline:0;max-width:clamp(560px,44vw,820px)}

  /* ---------- scroll cue: "there is more below" ---------- */
  .scrollcue{
    display:flex;flex-direction:column;align-items:center;gap:.6rem;
    position:absolute;left:50%;bottom:clamp(1.6rem,4vh,2.8rem);
    transform:translateX(-50%);width:max-content;
    color:var(--muted);font-family:var(--mono);font-size:.68rem;
    letter-spacing:.18em;text-transform:uppercase;
    transition:opacity .4s var(--ease),transform .4s var(--ease),color .2s var(--ease);
  }
  .scrollcue:hover{color:var(--soft)}
  .scrollcue .mouse{
    width:28px;height:44px;border:2px solid currentColor;border-radius:15px;
    display:flex;justify-content:center;padding-top:7px;opacity:.85;
  }
  .scrollcue .wheel{
    width:3.5px;height:9px;border-radius:3px;background:currentColor;
    animation:scwheel 1.6s var(--ease) infinite;
  }
  @keyframes scwheel{
    0%{opacity:0;transform:translateY(-4px)}
    30%,70%{opacity:1}
    100%{opacity:0;transform:translateY(9px)}
  }
  /* fades out once the visitor has started scrolling */
  .scrollcue.gone{opacity:0;transform:translateX(-50%) translateY(8px);pointer-events:none}
  /* pointless on mobile: people scroll instinctively, and the hero is already
     taller than the viewport there */
  @media (max-width:640px){.scrollcue{display:none}}
  @media (prefers-reduced-motion: reduce){
    .scrollcue,.scrollcue .wheel{animation:none;transition:none}
  }

</style>

<script>
  // fade the scroll cue out as soon as the visitor scrolls past the first fold
  const cue = document.querySelector<HTMLElement>('.scrollcue');
  if (cue) {
    const onScroll = () => {
      cue.classList.toggle('gone', window.scrollY > window.innerHeight * 0.35);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
