---
const steps = [
  ['You reach out', 'Tell me what you have and what you need. An email is plenty. No form with eleven required fields.'],
  ['I make a plan', 'A few questions, then a clear plan and a fixed price, all on one page.'],
  ['You give the go-ahead', 'Say the word, and I rebuild it from scratch.'],
  ['You go live', 'You get the finished site, ready to drop onto your host.'],
];
---

<section id="how">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="tag">pipeline</span>
        <h2>Four steps. <span class="grad">No fuss.</span></h2>
      </div>
      <p>A simple, visible process from first email to a live site. Nothing happens in a back room.</p>
    </div>

    <ol class="pipe">
      {steps.map(([title, body], i) => (
        <li class="stage reveal panel" style={`--reveal-delay:${i * 80}ms`}>
          <div class="top">
            <span class="node">{String(i + 1).padStart(2, '0')}</span>
            <span class="dots" aria-hidden="true"></span>
          </div>
          <h3>{title}</h3>
          <p>{body}</p>
        </li>
      ))}
    </ol>

    <div class="prep reveal">
      <div class="pchip">
        <span class="pk">Turnaround</span>
        <span class="pv">Depends on scope, estimated up front before any work begins</span>
      </div>
      <div class="pchip">
        <span class="pk">What I need from you</span>
        <span class="pv">Your current site or content, and a sentence on what you want done</span>
      </div>
    </div>
  </div>
</section>

<style>
  .pipe{list-style:none;display:grid;gap:1rem}
  @media (min-width:760px){.pipe{grid-template-columns:repeat(4,1fr)}}
  .stage{padding:1.3rem 1.3rem 1.5rem;position:relative;transition:transform .2s var(--ease),border-color .2s var(--ease)}
  .stage:hover{transform:translateY(-4px);border-color:rgba(79,140,255,.4)}
  .top{display:flex;align-items:center;gap:.7rem;margin-bottom:1rem}
  .node{
    flex:0 0 auto;width:2.4rem;height:2.4rem;border-radius:10px;display:grid;place-items:center;
    font-weight:800;font-size:.92rem;color:#fff;background:var(--grad);
    box-shadow:0 8px 18px -8px rgba(79,140,255,.6);
  }
  .dots{flex:1;height:2px;border-radius:2px;background:repeating-linear-gradient(90deg,var(--line-2) 0 6px,transparent 6px 12px)}
  .stage h3{font-weight:700;font-size:1.05rem;letter-spacing:-.01em;margin-bottom:.3rem}
  .stage p{color:var(--muted);font-size:.86rem;margin:0}

  .prep{display:grid;gap:1rem;margin-top:1.2rem}
  @media (min-width:760px){.prep{grid-template-columns:1fr 1fr}}
  .pchip{
    display:flex;flex-direction:column;gap:.35rem;
    padding:1.05rem 1.2rem;background:var(--panel-2);
    border:1px solid var(--line);border-radius:13px;
  }
  .pchip .pk{font-family:var(--mono);font-size:.64rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
  .pchip .pv{font-weight:700;font-size:.95rem;letter-spacing:-.01em;color:var(--text)}
</style>
