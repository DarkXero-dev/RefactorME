---
---

<section id="pricing">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="tag">pricing</span>
        <h2>Plain numbers. <span class="grad">No surprises.</span></h2>
      </div>
      <p>No packages, no tiers, no "contact us for enterprise pricing."</p>
    </div>

    <div class="panel pricebox reveal">
      <div class="left">
        <div class="k">Typical project range</div>
        <div class="amt"><span class="cur">€</span>150 <span class="to">to</span> <span class="cur">€</span>450</div>
        <p>Most projects land in this range, depending on what is involved. We tell you the price before we start.</p>
      </div>
      <div class="meta">
        <div class="mrow"><span>Quote</span><b>before any work</b></div>
        <div class="mrow"><span>Surprises</span><b class="good">none</b></div>
        <div class="mrow"><span>Who you deal with</span><b>the builder</b></div>
      </div>
    </div>

    <p class="guarantee reveal">
      <span class="gi" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v5c0 4.4-3 8.2-7 9.5C8 19.2 5 15.4 5 11V6l7-3z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      See a free preview before you pay a cent. Not happy with it? You don't pay.
    </p>
  </div>
</section>

<style>
  .pricebox{display:grid;gap:1.4rem;padding:clamp(1.6rem,4vw,2.4rem)}
  @media (min-width:760px){.pricebox{grid-template-columns:1.3fr 1fr;align-items:center}}
  .left .k{font-family:var(--mono);font-size:.66rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
  .amt{font-weight:800;font-size:clamp(2.2rem,1.4rem+3vw,3.4rem);letter-spacing:-.03em;line-height:1;margin:.6rem 0 1rem}
  .amt .cur{background:var(--grad-tri);-webkit-background-clip:text;background-clip:text;color:transparent;font-size:.7em}
  .amt .to{font-size:.4em;font-weight:600;color:var(--muted)}
  .left p{color:var(--muted);max-width:46ch;font-size:.92rem}
  .meta{display:grid;gap:.7rem}
  .mrow{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.7rem .9rem;background:var(--panel-2);border:1px solid var(--line);border-radius:11px;font-size:.86rem}
  .mrow span{color:var(--muted)}
  .mrow b{font-weight:700}
  .mrow b.good{color:var(--cyan)}

  .guarantee{
    display:flex;align-items:center;gap:.7rem;justify-content:center;text-align:center;
    margin-top:1.2rem;padding:.95rem 1.2rem;
    background:rgba(63,198,216,.07);border:1px solid rgba(63,198,216,.28);border-radius:13px;
    color:var(--soft);font-weight:600;font-size:.95rem;
  }
  .guarantee .gi{flex:0 0 auto;display:inline-flex;color:var(--cyan)}
  @media (max-width:480px){.guarantee{flex-direction:column;gap:.5rem;font-size:.9rem}}
</style>
