---
// The signature element: a tabbed dashboard card.
// Tab 1 (Preview): a live before/after rebuild. A grimy 2009 site crossfades
// into a clean modern one while a cyan scan line sweeps and the health score
// counts up. No cracks. CSS + a sliver of JS. Auto-plays on scroll, replayable.
// Tab 2 (Metrics): the performance chart (before vs after) plus headline stats.
// Respects reduced-motion.
---

<figure class="rb reveal panel" aria-label="A demonstration: an outdated website rebuilt into a modern one">
  <div class="tabs" role="tablist" aria-label="Rebuild preview">
    <button class="tab is-on" role="tab" aria-selected="true" data-tab="metrics" id="tab-metrics" aria-controls="pane-metrics">Metrics</button>
    <button class="tab" role="tab" aria-selected="false" data-tab="preview" id="tab-preview" aria-controls="pane-preview">Preview</button>
    <span class="urlchip">tonys-pizza.com</span>
  </div>

  <!-- PREVIEW TAB -->
  <div class="pane" id="pane-preview" role="tabpanel" aria-labelledby="tab-preview" hidden>
    <div class="head">
      <div class="ttl">
        <span class="t">Live rebuild preview</span>
        <span class="u">before vs after</span>
      </div>
      <div class="score">
        <span class="k">health</span>
        <span class="v"><b class="num">41</b><i class="of">/100</i></span>
      </div>
    </div>

    <div class="stage">
      <div class="site before">
        <div class="ribbon">~*~ WELCOME TO TONY'S PIZZA HOME PAGE ~*~</div>
        <h3>Tony's Pizzeria</h3>
        <p class="tagline"><i>Best Pizza In Town Since 1998</i></p>
        <p class="oldnav"><a href="#0">Home</a> | <a href="#0">Menu</a> | <a href="#0">Guestbook</a></p>
        <button class="bevel" type="button" tabindex="-1">Click Here For Specials!!!</button>
        <div class="oldbadges">
          <span class="ie">Best viewed in<br /><b>Internet Explorer 6</b></span>
          <span class="counter">visitors:<br /><b>00014<span class="blink">23</span></b></span>
        </div>
      </div>

      <div class="site after">
        <div class="bar">
          <span class="logo">Tony's</span>
          <nav class="newnav"><a href="#0">Menu</a><a href="#0">Hours</a><a href="#0">Find us</a></nav>
        </div>
        <h3>Wood-fired pizza,<br />made the slow way.</h3>
        <p class="sub">A small kitchen in the old town. Same family recipe since 1998, finally with a website to match.</p>
        <div class="row">
          <button class="cta" type="button" tabindex="-1">See the menu</button>
          <span class="chip">Open until 23:00</span>
        </div>
      </div>

      <span class="scan" aria-hidden="true"></span>
    </div>

    <div class="foot">
      <button class="replay" type="button" aria-live="polite">
        <span class="ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="15" height="15"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 1 0 3-6.7M3 4v5h5"/></svg>
        </span>
        <span class="replay-label">Watch the rebuild</span>
      </button>
      <span class="status">before</span>
      <span class="track" aria-hidden="true"><b class="fill"></b></span>
    </div>
  </div>

  <!-- METRICS TAB -->
  <div class="pane is-on" id="pane-metrics" role="tabpanel" aria-labelledby="tab-metrics">
    <div class="head">
      <div class="ttl">
        <span class="t">Performance over rebuild</span>
        <span class="u">last 8 checkpoints</span>
      </div>
      <div class="legend">
        <span><i style="background:var(--blue)"></i>Before</span>
        <span><i style="background:var(--cyan)"></i>After</span>
        <span><i style="background:var(--violet)"></i>Score</span>
      </div>
    </div>

    <div class="chartbox">
      <svg class="chart" viewBox="0 0 640 280" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Line chart showing performance improvement after the refactor">
        <defs>
          <linearGradient id="fillCyan" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#3fc6d8" stop-opacity="0.32"/>
            <stop offset="1" stop-color="#3fc6d8" stop-opacity="0"/>
          </linearGradient>
          <linearGradient id="lineGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0" stop-color="#4f8cff"/>
            <stop offset="0.5" stop-color="#3fc6d8"/>
            <stop offset="1" stop-color="#9b6cff"/>
          </linearGradient>
        </defs>
        <g stroke="#222c3f" stroke-width="1">
          <line x1="48" y1="40"  x2="620" y2="40"/>
          <line x1="48" y1="90"  x2="620" y2="90"/>
          <line x1="48" y1="140" x2="620" y2="140"/>
          <line x1="48" y1="190" x2="620" y2="190"/>
          <line x1="48" y1="240" x2="620" y2="240"/>
        </g>
        <line x1="48" y1="40" x2="48" y2="240" stroke="#2c374d" stroke-width="1.5"/>
        <line x1="48" y1="240" x2="620" y2="240" stroke="#2c374d" stroke-width="1.5"/>
        <g fill="#8b97ad" font-size="11" font-family="ui-monospace,monospace" text-anchor="end">
          <text x="40" y="44">100</text><text x="40" y="94">75</text><text x="40" y="144">50</text>
          <text x="40" y="194">25</text><text x="40" y="244">0</text>
        </g>
        <g fill="#8b97ad" font-size="11" font-family="ui-monospace,monospace" text-anchor="middle">
          <text x="80" y="262">w1</text><text x="157" y="262">w2</text><text x="234" y="262">w3</text>
          <text x="311" y="262">w4</text><text x="388" y="262">w5</text><text x="465" y="262">w6</text>
          <text x="542" y="262">w7</text><text x="610" y="262">w8</text>
        </g>
        <polyline fill="none" stroke="#4f8cff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="2 6" opacity="0.75"
          points="80,196 157,200 234,190 311,198 388,192 465,200 542,194 610,196"/>
        <path d="M80,188 L157,170 L234,150 L311,120 L388,96 L465,78 L542,62 L610,52 L610,240 L80,240 Z" fill="url(#fillCyan)"/>
        <polyline fill="none" stroke="url(#lineGrad)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"
          points="80,188 157,170 234,150 311,120 388,96 465,78 542,62 610,52"/>
        <g fill="#0f1420" stroke="#3fc6d8" stroke-width="2.5">
          <circle cx="80" cy="188" r="4"/><circle cx="157" cy="170" r="4"/><circle cx="234" cy="150" r="4"/>
          <circle cx="311" cy="120" r="4"/><circle cx="388" cy="96" r="4"/><circle cx="465" cy="78" r="4"/><circle cx="542" cy="62" r="4"/>
        </g>
        <circle cx="610" cy="52" r="5.5" fill="#9b6cff" stroke="#0f1420" stroke-width="2.5"/>
      </svg>
    </div>

    <div class="minigrid">
      <div class="mtile">
        <div class="k">Load time</div>
        <div class="v">0.8s</div>
        <div class="d up">71% faster</div>
        <div class="mbar"><b style="width:24%;background:linear-gradient(90deg,var(--blue),var(--cyan))"></b></div>
      </div>
      <div class="mtile">
        <div class="k">Mobile score</div>
        <div class="v">98</div>
        <div class="d up">from 54</div>
        <div class="mbar"><b style="width:98%;background:linear-gradient(90deg,var(--cyan),var(--violet))"></b></div>
      </div>
      <div class="mtile">
        <div class="k">Page weight</div>
        <div class="v">312<small> kb</small></div>
        <div class="d down">4.1 MB cut</div>
        <div class="mbar"><b style="width:18%;background:linear-gradient(90deg,var(--violet),var(--blue))"></b></div>
      </div>
    </div>
  </div>
</figure>

<style>
  .rb{padding:14px;max-width:560px;margin-inline:auto;box-shadow:var(--shadow)}

  /* tab bar */
  .tabs{display:flex;align-items:center;gap:.4rem;padding:2px 4px 12px}
  .tab{
    font-family:var(--sans);font-size:.78rem;font-weight:600;color:var(--muted);
    background:transparent;border:1px solid transparent;border-radius:9px;
    padding:.42rem .8rem;cursor:pointer;transition:.18s var(--ease);
  }
  .tab:hover{color:var(--text)}
  .tab.is-on{color:var(--text);background:var(--panel-2);border-color:var(--line)}
  .urlchip{margin-left:auto;font-family:var(--mono);font-size:.66rem;color:var(--muted)}

  .pane{display:none}
  .pane.is-on{display:block}

  .head{display:flex;align-items:center;justify-content:space-between;padding:2px 6px 12px}
  .ttl{display:flex;flex-direction:column;gap:2px}
  .ttl .t{font-size:.84rem;font-weight:600;color:#cdd6e6}
  .ttl .u{font-family:var(--mono);font-size:.68rem;color:var(--muted)}
  .score{text-align:right}
  .score .k{display:block;font-family:var(--mono);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
  .score .v{font-size:1.1rem;font-weight:800;letter-spacing:-.02em}
  .score .num{color:var(--blue);transition:color .5s var(--ease)}
  .score .of{font-size:.7rem;font-weight:600;color:var(--muted);font-style:normal}
  .rb.done .score .num{color:var(--cyan)}
  .legend{display:flex;gap:.9rem;font-size:.68rem;color:var(--muted)}
  .legend span{display:flex;align-items:center;gap:.35rem}
  .legend i{width:9px;height:9px;border-radius:3px;display:inline-block}

  .stage{
    position:relative;min-height:clamp(290px, 58vw, 340px);
    border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;background:#0c111b;
  }
  .site{position:absolute;inset:0;padding:clamp(1rem,4vw,1.6rem)}

  /* BEFORE */
  .before{
    background:repeating-linear-gradient(45deg,#e8e6cf 0 16px,#e2e0c6 16px 32px);
    font-family:'Times New Roman', Times, serif;color:#16357a;text-align:center;
    display:flex;flex-direction:column;align-items:center;gap:.5rem;filter:saturate(.9) brightness(.94);
  }
  .ribbon{width:100%;background:#8a2f1c;color:#ffe08a;font-family:Arial,sans-serif;font-size:.7rem;font-weight:700;padding:.3rem;margin:-.3rem 0 .2rem}
  .before h3{font-size:clamp(1.5rem,6vw,2rem);font-weight:700;color:#a01f28;text-shadow:1.5px 1.5px 0 #d9b73f;line-height:1.1}
  .before .tagline{color:#147a14;font-size:.95rem}
  .before .oldnav{font-size:.9rem}
  .before .oldnav a{color:#0000ee;text-decoration:underline}
  .before .bevel{font-family:Arial,sans-serif;font-size:.8rem;font-weight:700;color:#111;background:linear-gradient(#fafafa,#c6c6c6);border:2px outset #ddd;padding:.3rem .7rem;cursor:default}
  .before .oldbadges{display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;margin-top:.35rem}
  .before .ie,.before .counter{font-family:Arial,sans-serif;font-size:.6rem;line-height:1.3;border:1px solid #777;padding:.26rem .42rem;background:#fff;color:#222}
  .before .ie{background:#001a72;color:#fff;border-color:#000}
  .before .counter b{font-family:'Courier New',monospace;letter-spacing:.05em}
  .before .blink{animation:demo-blink 1s steps(1) infinite}
  @keyframes demo-blink{50%{opacity:0}}

  /* AFTER: deliberately a DIFFERENT palette and style from the landing page
     (warm cream/charcoal/terracotta editorial, fits a pizzeria) to show range. */
  .after{
    background:radial-gradient(130% 130% at 0% 0%, #fdf7ec, #f1e3cd 78%);
    color:#2c2620;display:flex;flex-direction:column;gap:.7rem;opacity:0;transform:scale(1.012);pointer-events:none;
  }
  .rb.done .after{opacity:1;transform:none}
  .after .bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:.3rem}
  .after .logo{font-family:Georgia,'Times New Roman',serif;font-weight:700;font-style:italic;font-size:1.25rem;letter-spacing:-.01em;color:#b5462b}
  .after .newnav{display:flex;gap:1rem}
  .after .newnav a{color:#8a7768;font-size:.82rem;font-weight:600}
  .after .newnav a:hover{color:#b5462b}
  .after h3{font-family:Georgia,'Times New Roman',serif;font-weight:700;font-size:clamp(1.45rem,5.4vw,2.05rem);line-height:1.06;letter-spacing:-.01em;margin-top:.3rem;color:#2c2620}
  .after .sub{color:#6b5c4d;font-size:.9rem;max-width:38ch;line-height:1.5}
  .after .row{display:flex;align-items:center;gap:.9rem;flex-wrap:wrap;margin-top:.4rem}
  .after .cta{font-weight:700;font-size:.86rem;color:#fdf7ec;background:#c4623f;border:none;border-radius:10px;padding:.55rem 1rem;cursor:default;box-shadow:0 10px 24px -10px rgba(150,60,30,.55)}
  .after .chip{font-size:.74rem;font-weight:700;color:#9a5326;background:rgba(196,98,63,.14);border:1px solid rgba(196,98,63,.32);border-radius:999px;padding:.32rem .7rem}

  /* scan sweep */
  .scan{position:absolute;top:-4%;bottom:-4%;left:-12%;width:10%;z-index:4;pointer-events:none;opacity:0;
    background:linear-gradient(90deg, transparent, rgba(63,198,216,.0) 10%, rgba(63,198,216,.85), rgba(207,243,248,.95), rgba(63,198,216,.85), transparent);
    box-shadow:0 0 26px 6px rgba(63,198,216,.35)}
  .rb.running .scan{animation:scan 1.5s var(--ease) forwards}
  @keyframes scan{0%{opacity:0;left:-12%}10%{opacity:1}90%{opacity:1}100%{opacity:0;left:102%}}
  .rb.instant .after,.rb.instant .scan{transition:none}

  /* footer / control */
  .foot{display:flex;align-items:center;gap:.9rem;margin-top:.95rem;padding:0 4px;flex-wrap:wrap}
  .replay{font-family:var(--sans);font-size:.82rem;font-weight:600;color:var(--text);background:var(--panel-2);border:1px solid var(--line);border-radius:999px;padding:.5rem .9rem;display:inline-flex;align-items:center;gap:.5rem;cursor:pointer;transition:border-color .2s var(--ease), color .2s var(--ease), transform .2s var(--ease)}
  .replay:hover{border-color:var(--blue);color:var(--cyan);transform:translateY(-1px)}
  .replay .ico{display:inline-flex;transition:transform .5s var(--ease)}
  .replay:hover .ico{transform:rotate(-180deg)}
  .status{font-family:var(--mono);font-size:.66rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
  .rb.running .status,.rb.done .status{color:var(--cyan)}
  .track{flex:1 1 80px;height:4px;min-width:70px;border-radius:3px;background:#1f2a3d;overflow:hidden}
  .track .fill{display:block;height:100%;width:0;border-radius:3px;background:linear-gradient(90deg,var(--blue),var(--cyan),var(--violet));transition:width 1.5s var(--ease)}
  .rb.running .track .fill,.rb.done .track .fill{width:100%}
  .rb.instant .track .fill{transition:none;width:0}

  /* metrics tab */
  .chartbox{background:#121826;border:1px solid var(--line);border-radius:14px;padding:14px 12px 8px}
  svg.chart{display:block;width:100%;height:auto}
  .minigrid{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;margin-top:.75rem}
  .mtile{background:var(--panel-deep);border:1px solid var(--line);border-radius:12px;padding:.75rem .8rem}
  .mtile .k{font-family:var(--mono);font-size:.6rem;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
  .mtile .v{font-size:1.3rem;font-weight:800;letter-spacing:-.02em;margin-top:.35rem}
  .mtile .v small{font-size:.72rem;color:var(--muted)}
  .mtile .d{font-size:.66rem;margin-top:.15rem;font-weight:600}
  .mtile .d.up{color:var(--cyan)}
  .mtile .d.down{color:var(--blue)}
  .mbar{height:4px;border-radius:3px;margin-top:.5rem;background:#1f2a3d;overflow:hidden}
  .mbar b{display:block;height:100%;border-radius:3px}

  @media (max-width:480px){.minigrid{grid-template-columns:1fr 1fr}}

  @media (prefers-reduced-motion: reduce){
    .scan{display:none}
    .before .blink{animation:none}
    .after,.track .fill{transition:none}
  }
</style>

<script>
  const demo = document.querySelector<HTMLElement>('.rb');
  if (demo) {
    // --- tabs ---
    const tabs = Array.from(demo.querySelectorAll<HTMLButtonElement>('.tab'));
    const panes = {
      preview: demo.querySelector<HTMLElement>('#pane-preview'),
      metrics: demo.querySelector<HTMLElement>('#pane-metrics'),
    };
    let everShown = false;
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const which = tab.dataset.tab as 'preview' | 'metrics';
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle('is-on', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        (['preview', 'metrics'] as const).forEach((key) => {
          const p = panes[key];
          if (!p) return;
          const on = key === which;
          p.classList.toggle('is-on', on);
          p.hidden = !on;
        });
        // play the rebuild the first time the Preview tab is opened
        if (which === 'preview' && !everShown) {
          everShown = true;
          if (reduce) {
            demo!.classList.add('done');
            setStatus('after');
            if (num) num.textContent = '94';
            if (label) label.textContent = 'Show the before';
          } else {
            window.setTimeout(play, 250);
          }
        }
      });
    });

    // --- before/after rebuild ---
    const btn = demo.querySelector<HTMLButtonElement>('.replay');
    const status = demo.querySelector<HTMLElement>('.status');
    const num = demo.querySelector<HTMLElement>('.score .num');
    const label = demo.querySelector<HTMLElement>('.replay-label');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let playing = false;
    let countTimer = 0;

    const setStatus = (t: string) => { if (status) status.textContent = t; };

    function countTo(target: number) {
      if (!num) return;
      window.clearInterval(countTimer);
      let cur = parseInt(num.textContent || '41', 10);
      countTimer = window.setInterval(() => {
        cur += Math.max(1, Math.round((target - cur) / 6));
        if (cur >= target) { cur = target; window.clearInterval(countTimer); }
        num.textContent = String(cur);
      }, 70);
    }

    function play() {
      if (playing) return;
      playing = true;
      if (label) label.textContent = 'Watch it again';
      demo!.classList.add('instant');
      demo!.classList.remove('done', 'running');
      if (num) num.textContent = '41';
      void demo!.offsetWidth;
      demo!.classList.remove('instant');
      setStatus('before');
      window.setTimeout(() => { setStatus('rebuilding'); demo!.classList.add('running'); }, 950);
      window.setTimeout(() => { demo!.classList.add('done'); setStatus('after'); countTo(94); }, 1250);
      window.setTimeout(() => { demo!.classList.remove('running'); playing = false; }, 2650);
    }

    function toggleInstant() {
      const done = demo!.classList.toggle('done');
      setStatus(done ? 'after' : 'before');
      if (num) num.textContent = done ? '94' : '41';
      if (label) label.textContent = done ? 'Show the before' : 'Show the after';
    }

    btn?.addEventListener('click', () => (reduce ? toggleInstant() : play()));
  }
</script>
