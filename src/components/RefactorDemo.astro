---
// The signature element: a live before/after rebuild card.
// A grimy 2009 site crossfades into a clean modern one while a cyan scan line
// sweeps and the health score counts up (41 -> 94). No cracks. CSS + a sliver
// of JS. Auto-LOOPS on a ~16s cycle while in view (no replay button); pauses
// when scrolled offscreen or the tab is hidden. No tabs: the numbers live in
// the deliverables section (WhatYouGet), so the rebuild is the whole card and
// is visible with zero clicks. Respects reduced-motion (static "after").
---

<figure class="rb reveal panel" aria-label="A demonstration: an outdated website rebuilt into a modern one">
  <div class="head">
    <div class="ttl">
      <span class="t">Live rebuild preview</span>
      <span class="u"><span class="urlchip ex-light">tonys-pizza.com</span><span class="urlchip ex-dark">netcore.io</span> · before vs after</span>
    </div>
    <div class="score">
      <span class="k">health</span>
      <span class="v"><b class="num">41</b><i class="of">/100</i></span>
    </div>
  </div>

  <div class="stage ex-light">
    <div class="site before">
      <div class="ribbon">~*~ WELCOME TO TONY'S PIZZA HOME PAGE ~*~</div>
      <h3>Tony's Pizzeria</h3>
      <p class="tagline"><i>Best Pizza In Town Since 1998</i></p>
      <p class="oldnav"><a href="#0">Home</a> | <a href="#0">Menu</a> | <a href="#0">Guestbook</a></p>
      <button class="bevel" type="button" tabindex="-1">Click Here For Specials!!!</button>
      <div class="oldbadges">
        <span class="ie">Best viewed in<br /><b>Internet Explorer 6</b></span>
        <span class="counter">visitors:<br /><b>00014<span class="blink">23</span></b></span>
      </div>
    </div>

    <div class="site after">
      <div class="bar">
        <span class="logo">Tony's</span>
        <nav class="newnav"><a href="#0">Menu</a><a href="#0">Hours</a><a href="#0">Find us</a></nav>
      </div>
      <h3>Wood-fired pizza,<br />made the slow way.</h3>
      <p class="sub">A small kitchen in the old town. Same family recipe since 1998, finally with a website to match.</p>
      <div class="row">
        <button class="cta" type="button" tabindex="-1">See the menu</button>
        <span class="chip">Open until 23:00</span>
      </div>
    </div>

    <span class="scan" aria-hidden="true"></span>
  </div>

  <div class="stage ex-dark">
    <div class="site nbefore">
      <div class="tb-hdr"><span>CyberTech Systems Inc.</span><span class="tb-win">_ &#9633; &#10005;</span></div>
      <h3>Your #1 Internet Solutions Provider!</h3>
      <p class="tb-tag"><span class="blink">*** UNDER CONSTRUCTION ***</span></p>
      <p class="tb-nav"><a href="#0">Home</a> | <a href="#0">Services</a> | <a href="#0">Webmaster</a></p>
      <button class="tb-btn" type="button" tabindex="-1">Enter Our Website</button>
      <div class="tb-badges">
        <span class="tb-b1">Best viewed in<br /><b>Netscape 4</b></span>
        <span class="tb-b2">You are visitor<br /><b>00<span class="blink">4821</span></b></span>
      </div>
    </div>

    <div class="site nafter">
      <div class="ta-bar">
        <span class="ta-brand">NETCORE</span>
        <nav class="ta-nav"><a href="#0">Systems</a><a href="#0">Cloud</a><a class="ta-jack" href="#0">Jack In</a></nav>
      </div>
      <span class="ta-kicker">// next-gen infrastructure //</span>
      <h3>Deploy to the <span class="cy">neon grid</span>.</h3>
      <p class="ta-sub">Bare-metal speed, edge everywhere. Ship in seconds, scale without limits.</p>
      <div class="ta-row">
        <button class="ta-cta" type="button" tabindex="-1">Launch console</button>
      </div>
    </div>

    <span class="scan" aria-hidden="true"></span>
  </div>

  <div class="foot">
    <span class="loops" aria-hidden="true">
      <span class="ldot"></span>auto rebuild
    </span>
    <span class="status">before</span>
    <span class="track" aria-hidden="true"><b class="fill"></b></span>
  </div>
</figure>

<style>
  /* animatable wipe position, so the soft-edged reveal can transition */
  @property --wipe{syntax:'<percentage>';inherits:false;initial-value:0%}

  .rb{padding:14px;max-width:560px;margin-inline:auto;box-shadow:var(--shadow)}
  .urlchip{font-family:var(--mono);font-size:.66rem;color:var(--muted)}

  .head{display:flex;align-items:center;justify-content:space-between;padding:2px 6px 12px}
  .ttl{display:flex;flex-direction:column;gap:2px}
  .ttl .t{font-size:.84rem;font-weight:600;color:var(--text)}
  .ttl .u{font-family:var(--mono);font-size:.68rem;color:var(--muted)}
  .score{text-align:right}
  .score .k{display:block;font-family:var(--mono);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
  .score .v{font-size:1.1rem;font-weight:800;letter-spacing:-.02em}
  .score .num{color:var(--blue);transition:color .5s var(--ease)}
  .score .of{font-size:.7rem;font-weight:600;color:var(--muted);font-style:normal}
  .rb.done .score .num{color:var(--cyan)}

  .stage{
    position:relative;min-height:clamp(290px, 58vw, 340px);
    border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;background:var(--stage);
  }
  .site{position:absolute;inset:0;padding:clamp(1rem,4vw,1.6rem)}

  /* two worked examples: Tony's Pizza (dark theme) + Nordic Roast (light theme).
     each theme shows exactly one; the other is removed from flow. */
  .stage.ex-light{display:none}
  .urlchip.ex-light{display:none}
  :global(:root[data-theme="light"]) .stage.ex-dark{display:none}
  :global(:root[data-theme="light"]) .urlchip.ex-dark{display:none}
  :global(:root[data-theme="light"]) .stage.ex-light{display:block}
  :global(:root[data-theme="light"]) .urlchip.ex-light{display:inline}

  /* BEFORE */
  .before{
    background:repeating-linear-gradient(45deg,#e8e6cf 0 16px,#e2e0c6 16px 32px);
    font-family:'Times New Roman', Times, serif;color:#16357a;text-align:center;
    display:flex;flex-direction:column;align-items:center;gap:.5rem;filter:saturate(.9) brightness(.94);
  }
  .ribbon{width:100%;background:#8a2f1c;color:#ffe08a;font-family:Arial,sans-serif;font-size:.7rem;font-weight:700;padding:.3rem;margin:-.3rem 0 .2rem}
  .before h3{font-size:clamp(1.5rem,6vw,2rem);font-weight:700;color:#a01f28;text-shadow:1.5px 1.5px 0 #d9b73f;line-height:1.1}
  .before .tagline{color:#147a14;font-size:.95rem}
  .before .oldnav{font-size:.9rem}
  .before .oldnav a{color:#0000ee;text-decoration:underline}
  .before .bevel{font-family:Arial,sans-serif;font-size:.8rem;font-weight:700;color:#111;background:linear-gradient(#fafafa,#c6c6c6);border:2px outset #ddd;padding:.3rem .7rem;cursor:default}
  .before .oldbadges{display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;margin-top:.35rem}
  .before .ie,.before .counter{font-family:Arial,sans-serif;font-size:.6rem;line-height:1.3;border:1px solid #777;padding:.26rem .42rem;background:#fff;color:#222}
  .before .ie{background:#001a72;color:#fff;border-color:#000}
  .before .counter b{font-family:'Courier New',monospace;letter-spacing:.05em}
  .before .blink{animation:demo-blink 1s steps(1) infinite}
  @keyframes demo-blink{50%{opacity:0}}

  /* AFTER: deliberately a DIFFERENT palette and style from the landing page
     (warm cream/charcoal/terracotta editorial, fits a pizzeria) to show range. */
  .after{
    background:radial-gradient(140% 140% at 0% 0%, #ffffff, #fbf1ec 88%);
    color:#26201d;display:flex;flex-direction:column;gap:.7rem;pointer-events:none;
    /* soft-edged reveal that rides the scan line: a 13% crossfade band at the
       wipe edge. linear so it stays locked to the (linear) scan both ways. */
    --wipe:0%;
    -webkit-mask-image:linear-gradient(90deg,#000 calc(var(--wipe) - 13%),transparent var(--wipe));
    mask-image:linear-gradient(90deg,#000 calc(var(--wipe) - 13%),transparent var(--wipe));
    transition:--wipe 4s linear;
  }
  .rb.done .after{--wipe:113%}
  .after .bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:.3rem}
  .after .logo{font-family:Georgia,'Times New Roman',serif;font-weight:700;font-style:italic;font-size:1.25rem;letter-spacing:-.01em;color:#d1402e}
  .after .newnav{display:flex;gap:1rem}
  .after .newnav a{color:#857b74;font-size:.82rem;font-weight:600}
  .after .newnav a:hover{color:#d1402e}
  .after h3{font-family:Georgia,'Times New Roman',serif;font-weight:700;font-size:clamp(1.45rem,5.4vw,2.05rem);line-height:1.06;letter-spacing:-.01em;margin-top:.3rem;color:#221d1a}
  .after .sub{color:#6f645d;font-size:.9rem;max-width:38ch;line-height:1.5}
  .after .row{display:flex;align-items:center;gap:.9rem;flex-wrap:wrap;margin-top:.4rem}
  .after .cta{font-weight:700;font-size:.86rem;color:#fff;background:#d1402e;border:none;border-radius:10px;padding:.55rem 1rem;cursor:default;box-shadow:0 10px 24px -10px rgba(209,64,46,.55)}
  .after .chip{font-size:.74rem;font-weight:700;color:#2f6b39;background:rgba(63,125,68,.12);border:1px solid rgba(63,125,68,.32);border-radius:999px;padding:.32rem .7rem}

  /* ===== old tech -> new tech (light-theme example) =====
     Shares nothing with Tony's: a dated Windows-98 corporate tech site rebuilt
     into a neon cyber-grid infra landing (cool magenta/cyan on near-black). */
  /* BEFORE: silver Windows-98 corporate site with a blue title bar */
  .nbefore{
    background:#c9ccd4;
    font-family:Tahoma,'Segoe UI','MS Sans Serif',Arial,sans-serif;color:#14142c;text-align:center;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;
  }
  .tb-hdr{width:100%;display:flex;align-items:center;justify-content:space-between;
    background:linear-gradient(#1e50e0,#000a8c);color:#fff;font-weight:700;font-size:.68rem;
    padding:.3rem .5rem;margin:-.3rem 0 .3rem;letter-spacing:.01em}
  .tb-win{font-family:'Courier New',monospace;letter-spacing:.12em;opacity:.9}
  .nbefore h3{font-size:clamp(1.15rem,4.4vw,1.55rem);font-weight:700;color:#000a8c;line-height:1.15}
  .tb-tag{color:#d10000;font-size:.9rem;font-weight:700}
  .tb-nav{font-size:.85rem}
  .tb-nav a{color:#0018cc;text-decoration:underline}
  .tb-btn{font-family:Tahoma,Arial,sans-serif;font-size:.8rem;color:#000;background:#dfe1e6;border:2px outset #f4f5f7;padding:.32rem .8rem;cursor:default}
  .tb-badges{display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;margin-top:.35rem}
  .tb-b1,.tb-b2{font-family:Arial,sans-serif;font-size:.58rem;line-height:1.3;border:1px solid #7a7f8a;padding:.24rem .4rem;background:#eef0f4;color:#222}
  .tb-b1{background:#000a8c;color:#fff;border-color:#000}
  .tb-b2 b{font-family:'Courier New',monospace;letter-spacing:.05em}

  /* AFTER: neon cyber-grid infra landing (dark #0a0a12, cyan + magenta glow,
     clip-path angles, mono/uppercase) - the 05.html synthwave vibe. */
  .nafter{
    background:
      radial-gradient(120% 95% at 50% 125%, rgba(255,61,166,.30), transparent 58%),
      radial-gradient(90% 60% at 50% -12%, rgba(45,226,230,.16), transparent 60%),
      linear-gradient(rgba(45,226,230,.10) 1px, transparent 1px),
      linear-gradient(90deg, rgba(45,226,230,.10) 1px, transparent 1px),
      #14142c;
    background-size:auto, auto, 30px 30px, 30px 30px, auto;
    color:#eef0ff;font-family:var(--mono);
    display:flex;flex-direction:column;gap:.5rem;justify-content:center;overflow:hidden;
    pointer-events:none;
    /* soft-edged reveal that rides the scan line (see .after) */
    --wipe:0%;
    -webkit-mask-image:linear-gradient(90deg,#000 calc(var(--wipe) - 13%),transparent var(--wipe));
    mask-image:linear-gradient(90deg,#000 calc(var(--wipe) - 13%),transparent var(--wipe));
    transition:--wipe 4s linear;
  }
  .rb.done .nafter{--wipe:113%}
  .ta-bar{
    display:flex;align-items:center;justify-content:space-between;gap:1rem;
    border:1px solid rgba(45,226,230,.4);background:rgba(10,10,18,.5);
    padding:.5rem .7rem;margin-bottom:.4rem;
    clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));
  }
  .ta-brand{font-size:.95rem;font-weight:700;letter-spacing:.16em;color:#2de2e6;text-shadow:0 0 8px rgba(45,226,230,.8)}
  .ta-nav{display:flex;gap:.85rem;align-items:center}
  .ta-nav a{color:#c7cbf0;font-size:.62rem;letter-spacing:.12em;text-transform:uppercase}
  .ta-nav a:hover{color:#ff3da6}
  .ta-jack{border:1px solid #ff3da6;color:#ff3da6;padding:.26rem .55rem;box-shadow:inset 0 0 12px rgba(255,61,166,.35)}
  .ta-kicker{align-self:flex-start;font-size:.58rem;letter-spacing:.26em;text-transform:uppercase;color:#2de2e6;border:1px solid rgba(45,226,230,.5);padding:.28rem .6rem}
  .nafter h3{font-family:var(--mono);font-weight:700;font-size:clamp(1.45rem,5.4vw,2.1rem);line-height:1.06;letter-spacing:.01em;margin-top:.2rem;color:#eef0ff;text-shadow:0 0 12px rgba(255,61,166,.55)}
  .nafter h3 .cy{color:#2de2e6;text-shadow:0 0 12px rgba(45,226,230,.75)}
  .ta-sub{color:#b9bce0;font-size:.85rem;max-width:34ch;line-height:1.5}
  .ta-row{margin-top:.5rem}
  .ta-cta{
    font-family:var(--mono);font-weight:700;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;
    color:#06121a;background:#2de2e6;border:none;padding:.6rem 1.2rem;cursor:default;
    clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));
    box-shadow:0 0 22px rgba(45,226,230,.6);
  }

  /* scan sweep */
  .scan{position:absolute;top:-4%;bottom:-4%;left:-12%;width:10%;z-index:4;pointer-events:none;opacity:0;
    background:linear-gradient(90deg, transparent, rgba(63,198,216,.0) 10%, rgba(63,198,216,.85), rgba(207,243,248,.95), rgba(63,198,216,.85), transparent);
    box-shadow:0 0 26px 6px rgba(63,198,216,.35)}
  .rb.running .scan{animation:scan 4s linear forwards}
  /* reverse pass (after -> before): the scan sweeps right -> left */
  .rb.rewind.running .scan{animation-direction:reverse}
  @keyframes scan{0%{opacity:0;left:-12%}10%{opacity:1}90%{opacity:1}100%{opacity:0;left:102%}}
  .rb.instant .after,.rb.instant .nafter,.rb.instant .scan{transition:none}

  /* footer / control */
  .foot{display:flex;align-items:center;gap:.9rem;margin-top:.95rem;padding:0 4px;flex-wrap:wrap}
  .loops{display:inline-flex;align-items:center;gap:.45rem;font-family:var(--mono);font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
  .loops .ldot{width:6px;height:6px;border-radius:50%;background:var(--cyan);box-shadow:0 0 7px 1px rgba(63,198,216,.6);animation:demo-loopdot 1.8s ease-in-out infinite}
  @keyframes demo-loopdot{0%,100%{opacity:.35;transform:scale(.85)}50%{opacity:1;transform:scale(1.15)}}
  .status{font-family:var(--mono);font-size:.66rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
  .rb.running .status,.rb.done .status{color:var(--cyan)}
  .track{flex:1 1 80px;height:4px;min-width:70px;border-radius:3px;background:var(--track);overflow:hidden}
  .track .fill{display:block;height:100%;width:0;border-radius:3px;background:linear-gradient(90deg,var(--blue),var(--cyan),var(--violet));transition:width 4s linear}
  .rb.done .track .fill{width:100%}
  .rb.instant .track .fill{transition:none;width:0}

  @media (prefers-reduced-motion: reduce){
    .scan{display:none}
    .before .blink{animation:none}
    .after,.nafter,.track .fill{transition:none}
    .loops .ldot{animation:none}
    .loops{display:none}
  }

  /* Large screens: scale the whole card up as one unit (panel height + every
     inner element together), so it grows with the hero instead of just widening. */
  @media (min-width:1360px){
    .rb{padding:18px}
    .head{padding:2px 8px 15px}
    .ttl .t{font-size:1rem}
    .ttl .u,.urlchip{font-size:.78rem}
    .score .k{font-size:.72rem}
    .score .v{font-size:1.35rem}
    .score .of{font-size:.82rem}

    .stage{min-height:clamp(270px,37vh,470px)}
    .site{padding:clamp(1.6rem,2.4vw,2.2rem)}

    .ribbon{font-size:.85rem}
    .before h3{font-size:clamp(2rem,3vw,2.55rem)}
    .before .tagline{font-size:1.14rem}
    .before .oldnav{font-size:1.08rem}
    .before .bevel{font-size:.95rem}
    .before .ie,.before .counter{font-size:.72rem}

    .after .logo{font-size:1.6rem}
    .after .newnav a{font-size:1rem}
    .after .newnav{gap:1.4rem}
    .after h3{font-size:clamp(2rem,3vw,2.6rem)}
    .after .sub{font-size:1.08rem;max-width:42ch}
    .after .cta{font-size:1.02rem;padding:.7rem 1.25rem}
    .after .chip{font-size:.88rem;padding:.4rem .85rem}

    .foot{margin-top:1.15rem}
    .loops{font-size:.74rem}
    .status{font-size:.76rem}
    .track{height:5px}
  }
</style>

<script>
  const demo = document.querySelector<HTMLElement>('.rb');
  if (demo) {
    const status = demo.querySelector<HTMLElement>('.status');
    const num = demo.querySelector<HTMLElement>('.score .num');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // slow, smooth ping-pong: before <-> after. Each direction is a crossfade
    // riding a scan sweep (durations match the CSS), with a dwell at each end.
    // No hard flip back at the end - it eases the other way instead.
    const TRANS = 4000;  // crossfade + scan sweep (see CSS 4s)
    const HOLD = 4200;   // dwell on each end before easing to the other side

    const setStatus = (t: string) => { if (status) status.textContent = t; };

    let countTimer = 0;
    let cycleTimer = 0;
    const steps: number[] = [];
    const clearTimers = () => {
      steps.forEach((id) => window.clearTimeout(id));
      steps.length = 0;
      window.clearTimeout(cycleTimer);
      window.clearInterval(countTimer);
    };
    const step = (fn: () => void, ms: number) => { steps.push(window.setTimeout(fn, ms)); };

    // count the health score toward a target, in either direction
    function countTo(target: number) {
      if (!num) return;
      window.clearInterval(countTimer);
      countTimer = window.setInterval(() => {
        let cur = parseInt(num!.textContent || '41', 10);
        const diff = target - cur;
        if (diff === 0) { window.clearInterval(countTimer); return; }
        const s = Math.max(1, Math.round(Math.abs(diff) / 8));
        cur += diff > 0 ? s : -s;
        if ((diff > 0 && cur >= target) || (diff < 0 && cur <= target)) cur = target;
        num!.textContent = String(cur);
      }, 90);
    }

    // ease BEFORE -> AFTER, then schedule the reverse
    function toAfter() {
      setStatus('rebuilding');
      demo!.classList.remove('rewind');   // forward pass: scan L -> R
      demo!.classList.add('running');
      demo!.classList.add('done');
      countTo(94);
      step(() => { demo!.classList.remove('running'); setStatus('after'); }, TRANS);
      cycleTimer = window.setTimeout(toBefore, TRANS + HOLD);
    }
    // ease AFTER -> BEFORE (the reverse crossfade, no flip), then schedule forward
    function toBefore() {
      setStatus('reverting');
      demo!.classList.add('rewind');      // reverse pass: scan R -> L
      demo!.classList.add('running');
      demo!.classList.remove('done');
      countTo(41);
      step(() => { demo!.classList.remove('running'); setStatus('before'); }, TRANS);
      cycleTimer = window.setTimeout(toAfter, TRANS + HOLD);
    }

    let running = false;
    function startLoop() {
      if (running || reduce) return;
      running = true;
      clearTimers();
      // snap cleanly to BEFORE (no transition), then begin the ping-pong
      demo!.classList.add('instant');
      demo!.classList.remove('done', 'running', 'rewind');
      if (num) num.textContent = '41';
      void demo!.offsetWidth;
      demo!.classList.remove('instant');
      setStatus('before');
      cycleTimer = window.setTimeout(toAfter, 1000);
    }
    function stopLoop() {
      running = false;
      clearTimers();
    }

    // reduced motion: no loop, just show the finished "after" state
    if (reduce) {
      demo.classList.add('done');
      setStatus('after');
      if (num) num.textContent = '94';
    } else {
      let inView = false;
      const refresh = () => {
        if (inView && !document.hidden) startLoop();
        else stopLoop();
      };

      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => { inView = en.isIntersecting; });
            refresh();
          },
          { threshold: 0.3 }
        );
        io.observe(demo);
      } else {
        inView = true;
        refresh();
      }

      // stop the loop while the tab is hidden, resume on return
      document.addEventListener('visibilitychange', refresh);
    }
  }
</script>
