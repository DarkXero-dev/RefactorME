---
// "Why?" section. A block that talks to the visitor: they pick what is bugging
// them about their current site, and the panel answers that exact concern in a
// calm, human line with a soft CTA. No backend, no input to abuse, no numbers,
// no screenshots. It gently rotates through the concerns on its own until the
// visitor interacts, then hands them control.
//
// Each pain carries a small line-icon so the option list reads like a real
// advisor rather than a row of tags.
const pains = [
  {
    key: 'slow',
    chip: 'It feels slow',
    icon: '<circle cx="12" cy="13" r="7.5"/><path d="M12 13V8.5"/><path d="M9.5 2.5h5"/><path d="M18.5 6.5l1.3-1.3"/>',
    answer:
      'A slow site loses people before it has finished loading. A rebuild throws out the dead weight, so your pages arrive before your visitor changes their mind.',
  },
  {
    key: 'dated',
    chip: 'It looks dated',
    icon: '<path d="M12 3l1.9 4.6L18.5 9l-4.6 1.4L12 15l-1.9-4.6L5.5 9l4.6-1.4z"/><path d="M18 15l.7 1.8L20.5 17.5l-1.8.7L18 20l-.7-1.8L15.5 17.5l1.8-.7z"/>',
    answer:
      'Your site is the first thing people judge you on, usually within seconds and rarely fairly. I rebuild it clean and current, so it looks as sharp as the work you actually do.',
  },
  {
    key: 'mobile',
    chip: "It's clumsy on phones",
    icon: '<rect x="7" y="2.5" width="10" height="19" rx="2.2"/><path d="M10.5 18.5h3"/>',
    answer:
      'Most of your visitors are on a phone, and a site that fights them on a small screen loses them. I build mobile-first, so everything reads and taps properly on any screen. That is not an upgrade, it is the job.',
  },
  {
    key: 'leads',
    chip: 'It brings no enquiries',
    icon: '<rect x="2.5" y="5" width="19" height="14" rx="2.2"/><path d="M3.5 7l8.5 6 8.5-6"/>',
    answer:
      'A site that looks fine but wins no work is decoration. I rework the layout and the calls to action, so visitors do the one thing you built it for and actually get in touch.',
  },
  {
    key: 'edit',
    chip: "I can't update it",
    icon: '<path d="M4 20l1-4L16.5 4.5a2 2 0 0 1 2.8 0l.2.2a2 2 0 0 1 0 2.8L8 19z"/><path d="M14.5 6.5l3 3"/>',
    answer:
      'If changing one line means emailing a developer, something has gone wrong. You get a site you can update yourself. Prefer to stay hands-off? Ongoing care is an optional add-on, never quietly bundled in.',
  },
];
---

<section id="rebuild" class="pains">
  <div class="wrap">
    <div class="pains-head reveal">
      <span class="tag">why refactor</span>
      <h2>What's bugging you about <span class="grad">your site</span>?</h2>
      <p>Pick whichever stings the most. Here is honestly what a rebuild does about it.</p>
    </div>

    <div class="panel picker reveal" data-picker>
      <div class="opts" role="tablist" aria-label="What's wrong with your site">
        {pains.map((p, i) => (
          <button
            class={`opt ${i === 0 ? 'on' : ''}`}
            role="tab"
            type="button"
            data-key={p.key}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            <svg class="ic" width="20" height="20" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true" set:html={p.icon} />
            <span>{p.chip}</span>
          </button>
        ))}
      </div>

      <div class="answer-wrap">
        <div class="answer" role="region" aria-live="polite">
          {pains.map((p, i) => (
            <p class={`ans ${i === 0 ? 'on' : ''}`} data-key={p.key}>{p.answer}</p>
          ))}
        </div>
        <a class="btn fixcta" href="#contact">
          Let's fix that
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .pains{padding-top:clamp(1rem,3vw,2rem)}
  .pains-head{text-align:center;max-width:52rem;margin:0 auto 1.6rem}
  .pains-head .tag{display:inline-block}
  .pains-head h2{max-width:none;text-wrap:balance}
  /* global p is justified; the subheading must stay centered */
  .pains-head p{color:var(--muted);font-size:.95rem;margin-top:.7rem;text-align:center;max-width:40ch;margin-inline:auto}

  /* ---- the card ---- */
  .picker{
    max-width:48rem;margin-inline:auto;
    display:grid;gap:clamp(.7rem,2vw,1.1rem);
    padding:clamp(.8rem,2.2vw,1.1rem);
  }
  @media (min-width:680px){
    .picker{grid-template-columns:16rem 1fr;align-items:start}
  }

  /* ---- left: option list ---- */
  .opts{display:flex;flex-direction:column;gap:.25rem}
  .opt{
    position:relative;display:flex;align-items:center;gap:.65rem;
    width:100%;text-align:left;
    font-family:var(--sans);font-size:.9rem;font-weight:600;
    color:var(--soft);background:transparent;
    border:1px solid transparent;border-radius:11px;
    padding:.6rem .75rem;cursor:pointer;
    transition:color .18s var(--ease),background .18s var(--ease),
               border-color .18s var(--ease),transform .18s var(--ease);
  }
  .opt .ic{width:20px;height:20px;flex:0 0 auto;color:var(--muted);transition:color .18s var(--ease)}
  .opt span{min-width:0}
  .opt:hover{background:var(--panel-2);color:var(--text)}
  .opt:hover .ic{color:var(--blue)}
  .opt.on{
    color:var(--text);
    background:linear-gradient(120deg,rgba(79,140,255,.16),rgba(155,108,255,.12));
    border-color:var(--line-2);
  }
  :root[data-theme="light"] .opt.on{
    background:linear-gradient(120deg,rgba(59,123,255,.12),rgba(122,79,224,.1));
  }
  /* accent bar on the active row */
  .opt.on::before{
    content:"";position:absolute;left:0;top:.6rem;bottom:.6rem;width:3px;
    border-radius:0 3px 3px 0;background:var(--grad-tri);
  }
  .opt.on .ic{color:var(--cyan)}

  /* ---- right: answer surface ---- */
  .answer-wrap{
    position:relative;overflow:hidden;
    background:var(--base);
    border:1px solid var(--line);border-radius:14px;
    padding:clamp(1rem,2.6vw,1.35rem);
    display:flex;flex-direction:column;justify-content:flex-start;gap:.95rem;
  }
  /* soft accent bloom in the corner so the panel isn't a flat rectangle */
  .answer-wrap::after{
    content:"";position:absolute;top:-40%;right:-20%;width:60%;height:120%;
    background:radial-gradient(circle,rgba(63,198,216,.14),transparent 62%);
    pointer-events:none;
  }
  /* grid stacking: every answer shares one cell, so the panel sizes to the
     tallest answer and nothing overflows onto the CTA below */
  .answer{position:relative;z-index:1;display:grid}
  .ans{
    grid-area:1 / 1;margin:0;color:var(--text);
    font-size:clamp(1.02rem,1rem + .3vw,1.16rem);line-height:1.55;
    text-align:left;-webkit-hyphens:none;hyphens:none;font-weight:500;
    opacity:0;transform:translateY(6px);pointer-events:none;
    transition:opacity .28s var(--ease),transform .28s var(--ease);
  }
  .ans.on{opacity:1;transform:none;pointer-events:auto}

  .fixcta{position:relative;z-index:1;font-size:.95rem;align-self:flex-start}

  @media (max-width:520px){
    .picker{padding:.75rem;gap:.65rem}
    .opts{gap:.2rem}
    .opt{font-size:.86rem;padding:.55rem .7rem}
    .answer-wrap{padding:.95rem 1rem;gap:.8rem}
    .fixcta{align-self:stretch;justify-content:center}
  }
  @media (prefers-reduced-motion: reduce){
    .ans,.opt{transition:none}
  }
</style>

<script>
  const picker = document.querySelector<HTMLElement>('[data-picker]');
  if (picker) {
    const opts = Array.from(picker.querySelectorAll<HTMLButtonElement>('.opt'));
    const answers = Array.from(picker.querySelectorAll<HTMLElement>('.ans'));
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const select = (key: string) => {
      opts.forEach((o) => {
        const on = o.dataset.key === key;
        o.classList.toggle('on', on);
        o.setAttribute('aria-selected', String(on));
      });
      answers.forEach((a) => a.classList.toggle('on', a.dataset.key === key));
    };

    // gentle self-rotation so the block shows it responds; stops for good the
    // moment the visitor engages (hover, focus, or click)
    let rotate = 0 as number | ReturnType<typeof setInterval>;
    let idx = 0;
    let stopped = false;
    const stop = () => {
      if (stopped) return;
      stopped = true;
      clearInterval(rotate as ReturnType<typeof setInterval>);
    };

    opts.forEach((o) =>
      o.addEventListener('click', () => {
        stop();
        select(o.dataset.key!);
      })
    );
    ['pointerenter', 'focusin'].forEach((ev) => picker.addEventListener(ev, stop));

    if (!reduce && opts.length > 1) {
      const startRotate = () => {
        if (stopped || rotate) return;
        rotate = setInterval(() => {
          idx = (idx + 1) % opts.length;
          select(opts[idx].dataset.key!);
        }, 4200);
      };
      // only rotate while the block is on screen
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) startRotate();
              else if (!stopped) {
                clearInterval(rotate as ReturnType<typeof setInterval>);
                rotate = 0;
              }
            });
          },
          { threshold: 0.35 }
        );
        io.observe(picker);
      } else {
        startRotate();
      }
    }
  }
</script>
