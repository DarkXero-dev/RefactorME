---
const cards = [
  {
    title: 'Small business sites',
    body: 'Cafes, shops, services. The site customers actually see, rebuilt fast, clean, and mobile-friendly.',
    color: 'blue',
    svg: '<rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M3 9h18" stroke="currentColor" stroke-width="2"/><circle cx="6" cy="7" r="0.6" fill="currentColor" stroke="none"/><circle cx="8.2" cy="7" r="0.6" fill="currentColor" stroke="none"/>',
  },
  {
    title: 'Hobby and personal pages',
    body: 'That passion project, club, or portfolio, rebuilt so it finally looks as good as the thing it is about.',
    color: 'violet',
    svg: '<path d="M4 7h11l3 3v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M7 3h9l3 3v3" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
  },
  {
    title: 'Single-product and landing pages',
    body: 'One product, one page, done right: fast, focused, and built to turn visitors into customers.',
    color: 'cyan',
    svg: '<rect x="4" y="3" width="16" height="18" rx="2" stroke="currentColor" stroke-width="2"/><path d="M8 8h8M8 12h8M8 16h5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  },
];
---

<section id="build">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="tag">what we rebuild</span>
        <h2>Every small site, <span class="grad">brought back to life</span>.</h2>
      </div>
      <p>One focus: refactoring tired sites into something fast, clean, and worth showing off.</p>
    </div>

    <div class="cards">
      {cards.map((c, i) => (
        <article class="card reveal panel" style={`--reveal-delay:${i * 80}ms`}>
          <span class="bar" aria-hidden="true"></span>
          <span class={`ic ${c.color}`} aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" set:html={c.svg} />
          </span>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cards{display:grid;gap:1.1rem}
  @media (min-width:760px){.cards{grid-template-columns:repeat(3,1fr)}}
  .card{position:relative;overflow:hidden;padding:1.6rem 1.5rem;transition:transform .22s var(--ease),border-color .22s var(--ease)}
  .card .bar{position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad-tri);opacity:0;transition:opacity .25s var(--ease)}
  .card:hover{transform:translateY(-5px);border-color:rgba(79,140,255,.4)}
  .card:hover .bar{opacity:1}
  .ic{display:inline-grid;place-items:center;width:3rem;height:3rem;border-radius:12px;margin-bottom:1.1rem}
  .ic.blue{background:rgba(79,140,255,.1);border:1px solid rgba(79,140,255,.25);color:var(--blue)}
  .ic.violet{background:rgba(155,108,255,.1);border:1px solid rgba(155,108,255,.25);color:var(--violet)}
  .ic.cyan{background:rgba(63,198,216,.1);border:1px solid rgba(63,198,216,.25);color:var(--cyan)}
  .card h3{font-weight:800;font-size:1.18rem;letter-spacing:-.02em;margin-bottom:.5rem}
  .card p{color:var(--muted);font-size:.92rem;margin:0}
</style>
