---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Refaktor.me, small sites rebuilt clean, fast, and done right",
  description = 'Refaktor.me rebuilds tired hobby pages, single-product sites, and the sites of family-run shops and restaurants. Faster, cleaner, happy on a phone, and no longer stuck in 2010.',
  image = '/og-refaktor.webp',
} = Astro.props;

// Absolute URLs for canonical + social cards (Astro.site = https://refaktor.me).
const site = Astro.site ?? new URL('https://refaktor.me');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;

// Structured data: a one-person website-refactoring service. Service (not
// ProfessionalService/Organization) because Refaktor is a person, not a
// registered entity.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Refaktor.me',
  description,
  url: site.href,
  image: ogImage,
  areaServed: 'Worldwide',
  serviceType: 'Website refactoring and rebuilding',
  provider: { '@type': 'Person', name: 'DarkXero' },
  offers: {
    '@type': 'Offer',
    description: 'Refactor and rebuild of hobby, single-product, and family-run shop websites',
    priceSpecification: { '@type': 'PriceSpecification', minPrice: 150, priceCurrency: 'EUR' },
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <!-- set the saved theme before first paint so there is no flash. Dark is default. -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('theme') === 'light') {
            document.documentElement.dataset.theme = 'light';
          }
        } catch (e) {}
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0f1420" />
    <meta name="color-scheme" content="dark light" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DarkXero" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Refaktor.me" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Refaktor.me: your website is calling for a refactor" />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link
      rel="preload"
      href="/fonts/schibsted-grotesk-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <slot />

    <script>
      // Gentle scroll reveal. No dependencies.
      // First paint: reveal whatever is already on screen with a small stagger.
      // After that: IntersectionObserver handles the rest as they enter.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));

      if (reduce) {
        els.forEach((el) => el.classList.add('in'));
      } else {
        const vh = window.innerHeight;
        const onscreen = els.filter((el) => el.getBoundingClientRect().top < vh * 0.92);
        onscreen.forEach((el, i) => {
          el.style.setProperty('--reveal-delay', `${Math.min(i, 6) * 80}ms`);
          requestAnimationFrame(() => el.classList.add('in'));
        });

        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((en) => {
                if (en.isIntersecting) {
                  en.target.classList.add('in');
                  io.unobserve(en.target);
                }
              });
            },
            { threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
          );
          els.filter((el) => !el.classList.contains('in')).forEach((el) => io.observe(el));
        } else {
          els.forEach((el) => el.classList.add('in'));
        }
      }
    </script>

    <script>
      // In-page links (nav, side rail, hero cue, CTAs) scroll smoothly WITHOUT
      // stamping #id into the address bar. One delegated handler covers them all.
      // scroll-padding-top (set in global.css) keeps the sticky header clear.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      document.addEventListener('click', (e) => {
        if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        const link = (e.target as HTMLElement).closest<HTMLAnchorElement>('a[href^="#"]');
        if (!link) return;
        const id = link.getAttribute('href')!.slice(1);
        if (!id) return; // ignore a bare "#"
        const target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
      });
    </script>
  </body>
</html>
