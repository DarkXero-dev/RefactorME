---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Refaktor.me, small sites rebuilt clean, fast, and done right",
  description = 'Refaktor.me rebuilds tired small business sites, hobby pages, and single-product sites. Faster, cleaner, mobile-friendly, and actually good.',
  image = '/og.webp',
} = Astro.props;

// Absolute URLs for canonical + social cards (Astro.site = https://refaktor.me).
const site = Astro.site ?? new URL('https://refaktor.me');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;

// Structured data: a one-person website-refactoring service.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Refaktor.me',
  description,
  url: site.href,
  image: ogImage,
  priceRange: '€150-€450',
  areaServed: 'Worldwide',
  serviceType: 'Website refactoring and rebuilding',
  founder: { '@type': 'Person', name: 'DarkXero' },
  makesOffer: {
    '@type': 'Offer',
    description: 'Refactor and rebuild of small business, hobby, and single-product websites',
    priceCurrency: 'EUR',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0f1420" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DarkXero" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Refaktor.me" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Refaktor.me, a live before and after site rebuild" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      // Gentle scroll reveal. No dependencies.
      // First paint: reveal whatever is already on screen with a small stagger.
      // After that: IntersectionObserver handles the rest as they enter.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));

      if (reduce) {
        els.forEach((el) => el.classList.add('in'));
      } else {
        const vh = window.innerHeight;
        const onscreen = els.filter((el) => el.getBoundingClientRect().top < vh * 0.92);
        onscreen.forEach((el, i) => {
          el.style.setProperty('--reveal-delay', `${Math.min(i, 6) * 80}ms`);
          requestAnimationFrame(() => el.classList.add('in'));
        });

        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((en) => {
                if (en.isIntersecting) {
                  en.target.classList.add('in');
                  io.unobserve(en.target);
                }
              });
            },
            { threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
          );
          els.filter((el) => !el.classList.contains('in')).forEach((el) => io.observe(el));
        } else {
          els.forEach((el) => el.classList.add('in'));
        }
      }
    </script>
  </body>
</html>
