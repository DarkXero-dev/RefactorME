---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhatWeFix from '../components/WhatWeFix.astro';
import PreviewGenerator from '../components/PreviewGenerator.astro';
import WhatYouGet from '../components/WhatYouGet.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhatWeBuild from '../components/WhatWeBuild.astro';
import SamplesSection from '../components/SamplesSection.astro';
import Pricing from '../components/Pricing.astro';
import Faq from '../components/Faq.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

// Site status switch. Default offline (red) until launch. Flip to true
// (PUBLIC_SITE_ONLINE=true) and rebuild to show green "online". See README.
const online = import.meta.env.PUBLIC_SITE_ONLINE === 'true';
---

<Layout>
  <header class="topbar">
    <div class="wrap inner">
      <a href="#top" class="brand">
        <span class="dot" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 17l5-5 4 3 7-8" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="word">Refaktor<span class="me">.me</span></span>
      </a>
      <nav class="nav">
        <div class="links">
          <a href="#fix">Diagnostics</a>
          <a href="#try">Live preview</a>
          <a href="#build">What we rebuild</a>
          <a href="#samples">Samples</a>
          <a href="#pricing">Pricing</a>
          <a href="#faq">FAQ</a>
        </div>
        <span class={`pill ${online ? 'on' : 'off'}`}>
          <span class="dot" aria-hidden="true"></span>{online ? 'online' : 'offline'}
        </span>
        <a class="btn cta-desktop" href="#contact">Get a refactor</a>
        <button class="menu-btn" id="menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="bars" aria-hidden="true"><i></i><i></i><i></i></span>
        </button>
      </nav>
    </div>

    <div class="mobile-menu" id="mobile-menu" hidden>
      <div class="wrap">
        <span class={`pill ${online ? 'on' : 'off'} m-pill`}>
          <span class="dot" aria-hidden="true"></span>{online ? 'online' : 'offline'}
        </span>
        <a href="#fix">Diagnostics</a>
        <a href="#try">Live preview</a>
        <a href="#build">What we rebuild</a>
        <a href="#samples">Samples</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
        <a class="btn m-cta" href="#contact">Get a refactor</a>
      </div>
    </div>
  </header>

  <main id="top">
    <Hero />
    <PreviewGenerator />
    <WhatWeFix />
    <WhatYouGet />
    <HowItWorks />
    <WhatWeBuild />
    <SamplesSection />
    <Pricing />
    <Faq />
    <Contact />
  </main>

  <Footer />

  <a class="mobile-cta" href="#contact">
    Get a refactor
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
</Layout>

<style>
  .topbar{
    position:sticky;top:0;z-index:50;
    border-bottom:1px solid var(--line);
    background:linear-gradient(180deg, rgba(15,20,32,.92), rgba(15,20,32,.6));
    backdrop-filter:saturate(140%) blur(10px);
    -webkit-backdrop-filter:saturate(140%) blur(10px);
  }
  .topbar .inner{display:flex;align-items:center;justify-content:space-between;height:64px}
  .brand{display:flex;align-items:center;gap:.7rem;font-weight:800;font-size:1.12rem;letter-spacing:-.02em;color:var(--text)}
  .brand .dot{width:30px;height:30px;border-radius:9px;display:grid;place-items:center;background:var(--grad);box-shadow:0 6px 18px rgba(79,140,255,.35)}
  .brand .me{color:var(--cyan)}
  .nav{display:flex;align-items:center;gap:1.6rem}
  .nav .links{display:flex;gap:1.5rem;font-size:.86rem;color:var(--muted);font-weight:500}
  .nav .links a:hover{color:var(--text)}
  .pill{
    font-family:var(--mono);font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;
    border:1px solid;border-radius:999px;padding:.36rem .7rem;
    display:inline-flex;align-items:center;gap:.42rem;
  }
  .pill .dot{
    width:7px;height:7px;border-radius:50%;flex:0 0 auto;
    animation:status-pulse 1.6s ease-in-out infinite;
  }
  /* offline: red, pulsating (default until launch) */
  .pill.off{color:#ff9093;border-color:rgba(226,72,77,.45);background:rgba(226,72,77,.1)}
  .pill.off .dot{background:#e2484d;box-shadow:0 0 8px 1px rgba(226,72,77,.7)}
  /* online: green, pulsating */
  .pill.on{color:#73e3b4;border-color:rgba(63,207,142,.45);background:rgba(63,207,142,.1)}
  .pill.on .dot{background:#3fcf8e;box-shadow:0 0 8px 1px rgba(63,207,142,.7)}
  @keyframes status-pulse{
    0%,100%{transform:scale(1);opacity:1}
    50%{transform:scale(1.3);opacity:.5}
  }
  @media (prefers-reduced-motion: reduce){.pill .dot{animation:none}}

  /* ---------- hamburger ---------- */
  .menu-btn{
    display:none;
    width:42px;height:42px;flex:0 0 auto;
    align-items:center;justify-content:center;
    background:transparent;border:1px solid var(--line);border-radius:11px;
    cursor:pointer;color:var(--text);
  }
  .menu-btn:hover{border-color:var(--blue)}
  .menu-btn .bars{display:grid;gap:4px;width:18px}
  .menu-btn .bars i{display:block;height:2px;border-radius:2px;background:currentColor;transition:transform .2s var(--ease), opacity .2s var(--ease)}
  .menu-btn[aria-expanded="true"] .bars i:nth-child(1){transform:translateY(6px) rotate(45deg)}
  .menu-btn[aria-expanded="true"] .bars i:nth-child(2){opacity:0}
  .menu-btn[aria-expanded="true"] .bars i:nth-child(3){transform:translateY(-6px) rotate(-45deg)}

  /* ---------- mobile dropdown panel ---------- */
  .mobile-menu{
    display:none;
    border-bottom:1px solid var(--line);
    background:linear-gradient(180deg, rgba(15,20,32,.98), rgba(15,20,32,.94));
    backdrop-filter:saturate(140%) blur(10px);
    -webkit-backdrop-filter:saturate(140%) blur(10px);
  }
  .mobile-menu .wrap{display:flex;flex-direction:column;gap:.2rem;padding-block:.8rem 1.1rem}
  .mobile-menu a{
    color:var(--soft);font-weight:600;font-size:1rem;
    padding:.8rem .4rem;border-bottom:1px solid var(--line);
  }
  .mobile-menu a:last-child{border-bottom:none}
  .mobile-menu a:not(.btn):hover{color:var(--text)}
  .mobile-menu .m-pill{align-self:flex-start;margin-bottom:.4rem}
  .mobile-menu .m-cta{
    justify-content:center;margin-top:.7rem;border-bottom:none;
    color:#fff;padding:.85rem 1.1rem;
  }
  /* hidden attr must win over the media-query display:block below (closed by default) */
  .mobile-menu[hidden]{display:none}

  @media (max-width:860px){
    .nav .links{display:none}
    .nav .cta-desktop{display:none}
    .nav .pill{display:none}
    .menu-btn{display:inline-flex}
    .mobile-menu{display:block}
  }
  @media (max-width:400px){
    .topbar .wrap{height:58px}
    .brand{font-size:1.05rem;gap:.5rem}
    .brand .dot{width:26px;height:26px}
    .nav{gap:.6rem}
  }

  /* ---------- sticky mobile CTA ---------- */
  .mobile-cta{
    display:none;
    position:fixed;left:0;right:0;bottom:0;z-index:60;
    align-items:center;justify-content:center;gap:.55rem;
    background:var(--grad);color:#fff;font-weight:700;font-size:1rem;
    padding:.95rem 1.2rem;
    padding-bottom:calc(.95rem + env(safe-area-inset-bottom));
    box-shadow:0 -8px 26px rgba(0,0,0,.4);
    border-top:1px solid rgba(255,255,255,.14);
    transition:transform .25s var(--ease), opacity .25s var(--ease);
  }
  @media (max-width:640px){.mobile-cta{display:flex}}
  /* slide out when the contact form is on screen (no point nagging there) */
  .mobile-cta.hide{transform:translateY(120%);opacity:0;pointer-events:none}
  @media (prefers-reduced-motion: reduce){.mobile-cta{transition:none}}
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    const setOpen = (open: boolean) => {
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      menu.hidden = !open;
    };
    btn.addEventListener('click', () => {
      setOpen(btn.getAttribute('aria-expanded') !== 'true');
    });
    // close after picking a destination
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    // close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') setOpen(false);
    });
  }

  // hide the sticky mobile CTA once the contact form (or the footer beyond it)
  // is in view, and keep it hidden all the way down so it never covers them
  const cta = document.querySelector<HTMLElement>('.mobile-cta');
  const contact = document.getElementById('contact');
  const footer = document.querySelector<HTMLElement>('footer');
  if (cta && contact && 'IntersectionObserver' in window) {
    const seen = new Set<Element>();
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) seen.add(en.target);
          else seen.delete(en.target);
        });
        cta.classList.toggle('hide', seen.size > 0);
      },
      { threshold: 0.18 }
    );
    io.observe(contact);
    if (footer) io.observe(footer);
  }
</script>
